services:
  godot-mcp-test:
    image: ghcr.io/n24q02m/better-godot-mcp:{{ image_tag | default('beta') }}
    ports:
      - "127.0.0.1:{{ host_port }}:8080"
    environment:
      MCP_HOST: "0.0.0.0"
      MCP_PORT: "8080"
      {% if godot_path is defined and godot_path -%}
      GODOT_PATH: "{{ godot_path }}"
      {%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/.well-known/oauth-authorization-server || curl -fsS http://127.0.0.1:8080/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 12
