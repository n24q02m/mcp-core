services:
  godot-mcp-test:
    image: ghcr.io/n24q02m/better-godot-mcp:{{ image_tag | default('beta') }}
    ports:
      - "127.0.0.1:{{ host_port }}:8080"
    environment:
      # init-server.ts reads HOST + PORT (uppercase) and forwards to runLocalServer.
      # Default host is 127.0.0.1 which is unreachable from the docker host port
      # mapping; bind 0.0.0.0 explicitly. Dockerfile bakes TRANSPORT_MODE=stdio
      # for ``npx`` users; override here so the daemon takes the HTTP branch.
      HOST: "0.0.0.0"
      PORT: "8080"
      MCP_TRANSPORT: "http"
      {% if godot_path is defined and godot_path -%}
      GODOT_PATH: "{{ godot_path }}"
      {%- endif %}
    healthcheck:
      # godot has no relaySchema -> no /.well-known/oauth-authorization-server.
      # /health is always available via runLocalServer; that is the canonical
      # readiness probe for no-auth servers.
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/health || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 12
