services:
  notion-mcp-test:
    image: ghcr.io/n24q02m/better-notion-mcp:{{ image_tag | default('beta') }}
    ports:
      - "127.0.0.1:{{ host_port }}:8080"
    environment:
      MCP_HOST: "0.0.0.0"
      MCP_PORT: "8080"
      {% if deployment == 'remote' -%}
      PUBLIC_URL: "http://127.0.0.1:{{ host_port }}"
      MCP_DCR_SERVER_SECRET: "{{ mcp_dcr_server_secret }}"
      {% if notion_oauth_client_id is defined and notion_oauth_client_id -%}
      NOTION_OAUTH_CLIENT_ID: "{{ notion_oauth_client_id }}"
      NOTION_OAUTH_CLIENT_SECRET: "{{ notion_oauth_client_secret }}"
      {%- endif %}
      {%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/health || curl -fsS http://127.0.0.1:8080/.well-known/oauth-authorization-server || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 12
