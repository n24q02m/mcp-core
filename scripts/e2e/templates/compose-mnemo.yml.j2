services:
  mnemo-mcp-test:
    image: ghcr.io/n24q02m/mnemo-mcp:{{ image_tag | default('beta') }}
    ports:
      - "127.0.0.1:{{ host_port }}:8080"
    environment:
      MCP_HOST: "0.0.0.0"
      MCP_PORT: "8080"
      # Docker E2E: always set PUBLIC_URL so the daemon binds 0.0.0.0:8080
      # (single-user local mode binds 127.0.0.1:<random>, unreachable from
      # outside the container). Both deployments test the multi-user remote
      # codepath; the per-isolation distinction (config.enc vs subs/<sub>)
      # is covered separately in tests/integration/test_multi_user_remote.py.
      PUBLIC_URL: "http://127.0.0.1:{{ host_port }}"
      MCP_DCR_SERVER_SECRET: "{{ mcp_dcr_server_secret }}"
      {% if jina_ai_api_key is defined and jina_ai_api_key -%}
      JINA_AI_API_KEY: "{{ jina_ai_api_key }}"
      {%- endif %}
      {% if gemini_api_key is defined and gemini_api_key -%}
      GEMINI_API_KEY: "{{ gemini_api_key }}"
      {%- endif %}
      {% if openai_api_key is defined and openai_api_key -%}
      OPENAI_API_KEY: "{{ openai_api_key }}"
      {%- endif %}
      {% if cohere_api_key is defined and cohere_api_key -%}
      COHERE_API_KEY: "{{ cohere_api_key }}"
      {%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8080/.well-known/oauth-authorization-server || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 24
