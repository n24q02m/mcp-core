services:
  email-mcp-test:
    image: ghcr.io/n24q02m/better-email-mcp:{{ image_tag | default('beta') }}
    ports:
      - "127.0.0.1:{{ host_port }}:8080"
    environment:
      MCP_HOST: "0.0.0.0"
      MCP_PORT: "8080"
      {% if deployment == 'remote' -%}
      PUBLIC_URL: "http://127.0.0.1:{{ host_port }}"
      MCP_DCR_SERVER_SECRET: "{{ mcp_dcr_server_secret }}"
      {%- endif %}
      {% if gmail_email is defined and gmail_email -%}
      GMAIL_EMAIL: "{{ gmail_email }}"
      GMAIL_APP_PASSWORD: "{{ gmail_app_password }}"
      {%- endif %}
      {% if outlook_email is defined and outlook_email -%}
      OUTLOOK_EMAIL: "{{ outlook_email }}"
      {%- endif %}
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:8080/.well-known/oauth-authorization-server || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 12
